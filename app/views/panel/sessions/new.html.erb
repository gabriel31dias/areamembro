<div class="auth-wrapper">
  <div class="auth-banner">
    <div class="banner-logo">
      <%= image_tag "logo-bluevision.png", alt: "Blue Vision Co.", class: "banner-logo-img" %>
      <p>Área de Membros</p>
    </div>
  </div>

  <div class="auth-container">
    <div class="auth-logo">
      <%= image_tag "logo-bluevision.png", alt: "Blue Vision Co.", class: "auth-logo-img" %>
      <p>Gestão de Cursos</p>
    </div>

    <% if flash[:alert] %>
      <div class="alert alert-danger"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: panel_login_path, method: :post, local: true do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, class: "form-input", placeholder: "seu@email.com", required: true, autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, class: "form-input", placeholder: "••••••••", required: true %>
      </div>

      <%= f.submit "Entrar", class: "btn-submit" %>
    <% end %>
  </div>
</div>
