<div style="max-width: 800px; margin: 0 auto; padding: 1rem;">
  <!-- Header -->
  <div style="margin-bottom: 1.5rem;">
    <%= link_to panel_course_path(@course), style: "display: inline-flex; align-items: center; gap: 0.5rem; color: #64748b; text-decoration: none; font-size: 0.875rem; transition: color 0.2s;", onmouseover: "this.style.color='#00d4ff'", onmouseout: "this.style.color='#64748b'" do %>
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Voltar para <%= @course.title %>
    <% end %>
  </div>

  <div style="background: white; border-radius: 20px; padding: 2.5rem; box-shadow: 0 2px 8px rgba(0,0,0,0.04); border: 1px solid rgba(0,0,0,0.06);">
    <!-- Title Section -->
    <div style="text-align: center; margin-bottom: 2.5rem;">
      <div style="width: 80px; height: 80px; border-radius: 20px; background: linear-gradient(135deg, #00d4ff 0%, #0066ff 100%); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; box-shadow: 0 8px 24px rgba(0, 102, 255, 0.25);">
        <svg width="40" height="40" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
        </svg>
      </div>
      <h1 style="font-weight: 800; color: #0a0e27; font-size: 2rem; margin-bottom: 0.5rem;">Editar Aula</h1>
      <p style="color: #64748b; font-size: 1rem;">Atualize as informações da aula</p>
    </div>

    <%= form_with model: [@course, @lesson], url: panel_course_lesson_path(@course, @lesson), method: :patch, local: true, multipart: true do |f| %>
      <% if @lesson.errors.any? %>
        <div style="background: #fee2e2; border-left: 4px solid #ef4444; border-radius: 12px; padding: 1.25rem; margin-bottom: 2rem;">
          <div style="display: flex; align-items: start; gap: 1rem;">
            <svg width="24" height="24" fill="none" stroke="#991b1b" viewBox="0 0 24 24" style="flex-shrink: 0;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div style="flex: 1;">
              <h3 style="color: #991b1b; font-weight: 600; margin-bottom: 0.75rem; font-size: 1rem;">
                <%= pluralize(@lesson.errors.count, "erro") %> encontrado<%= @lesson.errors.count > 1 ? 's' : '' %>
              </h3>
              <ul style="margin-left: 1.25rem; color: #991b1b; font-size: 0.875rem; line-height: 1.6;">
                <% @lesson.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <div style="display: grid; gap: 1.5rem;">
        <!-- Título e Ordem -->
        <div style="display: grid; grid-template-columns: 3fr 1fr; gap: 1.25rem;">
          <div>
            <%= f.label :title, "Título da Aula *", style: "display: block; font-weight: 600; color: #0a0e27; margin-bottom: 0.625rem; font-size: 0.875rem;" %>
            <%= f.text_field :title, placeholder: "Ex: Introdução ao Rails", style: "width: 100%; padding: 0.875rem 1rem; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 0.9375rem; transition: all 0.2s;", onfocus: "this.style.borderColor='#00d4ff'; this.style.boxShadow='0 0 0 3px rgba(0,212,255,0.1)'", onblur: "this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'", required: true %>
          </div>

          <div>
            <%= f.label :order_number, "Ordem *", style: "display: block; font-weight: 600; color: #0a0e27; margin-bottom: 0.625rem; font-size: 0.875rem;" %>
            <%= f.number_field :order_number, min: 1, style: "width: 100%; padding: 0.875rem 1rem; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 0.9375rem; transition: all 0.2s;", onfocus: "this.style.borderColor='#00d4ff'; this.style.boxShadow='0 0 0 3px rgba(0,212,255,0.1)'", onblur: "this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'", required: true %>
          </div>
        </div>

        <!-- Descrição -->
        <div>
          <%= f.label :description, "Descrição", style: "display: block; font-weight: 600; color: #0a0e27; margin-bottom: 0.625rem; font-size: 0.875rem;" %>
          <%= f.text_area :description, rows: 3, placeholder: "Descreva o conteúdo da aula...", style: "width: 100%; padding: 0.875rem 1rem; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 0.9375rem; resize: vertical; transition: all 0.2s;", onfocus: "this.style.borderColor='#00d4ff'; this.style.boxShadow='0 0 0 3px rgba(0,212,255,0.1)'", onblur: "this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'" %>
        </div>

        <!-- Upload de Vídeo (duração detectada automaticamente) -->
        <div>
          <%= f.label :video, "Vídeo da aula", style: "display: block; font-weight: 600; color: #0a0e27; margin-bottom: 0.625rem; font-size: 0.875rem;" %>
          <% if @lesson.video.attached? %>
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; padding: 0.75rem 1rem; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px;">
              <span style="font-size: 0.875rem; color: #059669; font-weight: 600;">✓ <%= @lesson.video.filename %></span>
              <video controls style="height: 60px; border-radius: 8px;" src="<%= @lesson.video_file_url %>"></video>
            </div>
            <p style="margin-bottom: 0.5rem; font-size: 0.75rem; color: #64748b;">Envie um novo arquivo para substituir o atual</p>
          <% end %>
          <%= f.file_field :video, accept: "video/mp4,video/webm,video/ogg,video/quicktime", onchange: "autoFillDuration(this)", style: "width: 100%; padding: 0.875rem 1rem; border: 2px dashed #e2e8f0; border-radius: 12px; font-size: 0.9375rem; background: #f8fafc;" %>
          <%= f.hidden_field :duration_minutes, value: f.object.duration_minutes || 0 %>
          <p style="margin-top: 0.5rem; font-size: 0.75rem; color: #64748b;">MP4, WEBM, OGG ou MOV (máx. 500MB) — a duração é detectada automaticamente</p>
          <p class="duration-display" style="margin-top: 0.5rem; font-size: 0.75rem; color: #10b981; font-weight: 600;"><% if @lesson.duration_minutes.to_i > 0 %>🎬 Duração: <%= @lesson.duration_minutes %> min<% end %></p>
        </div>
      </div>

      <!-- Actions -->
      <div style="display: flex; gap: 1rem; margin-top: 2.5rem; padding-top: 1.5rem; border-top: 2px solid #f1f5f9;">
        <%= f.submit "✓ Salvar Alterações", style: "flex: 1; padding: 1rem 1.5rem; background: linear-gradient(135deg, #00d4ff 0%, #0066ff 100%); color: white; border: none; border-radius: 12px; font-weight: 600; font-size: 1rem; cursor: pointer; box-shadow: 0 4px 12px rgba(0, 102, 255, 0.25); transition: all 0.2s;", onmouseover: "this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 20px rgba(0, 102, 255, 0.35)'", onmouseout: "this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(0, 102, 255, 0.25)'" %>
        <%= link_to panel_course_path(@course), style: "flex: 1; padding: 1rem 1.5rem; border: 2px solid #e2e8f0; color: #475569; border-radius: 12px; text-decoration: none; font-weight: 600; font-size: 1rem; text-align: center; transition: all 0.2s; display: flex; align-items: center; justify-content: center;", onmouseover: "this.style.borderColor='#cbd5e1'; this.style.background='#f8fafc'", onmouseout: "this.style.borderColor='#e2e8f0'; this.style.background='transparent'" do %>
          Cancelar
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<script>
  // Lê a duração do vídeo selecionado (metadados, no navegador) e preenche o campo oculto duration_minutes
  function autoFillDuration(input) {
    const scope = input.closest('form');
    if (!scope) return;
    const durationField = scope.querySelector('input[name*="[duration_minutes]"]');
    const display = scope.querySelector('.duration-display');
    const file = input.files && input.files[0];
    if (!file || !durationField) return;

    const url = URL.createObjectURL(file);
    const video = document.createElement('video');
    video.preload = 'metadata';
    video.onloadedmetadata = function () {
      URL.revokeObjectURL(url);
      const minutes = Math.max(1, Math.round(video.duration / 60));
      durationField.value = minutes;
      if (display) display.textContent = '🎬 Duração detectada: ' + minutes + ' min';
    };
    video.onerror = function () {
      URL.revokeObjectURL(url);
      if (display) display.textContent = '';
    };
    video.src = url;
  }
</script>
